rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function inTenant(tenantId) {
      return signedIn() && request.auth.token.tenantId == tenantId;
    }
    function hasRole(tenantId, roles) {
      return inTenant(tenantId) && request.auth.token.role in roles;
    }

    match /tenants/{tenantId} {
      allow read: if inTenant(tenantId);
      allow write: if false; // tenants are created only by the seed script / admin SDK

      match /staff/{staffId} {
        allow read: if inTenant(tenantId);
        allow write: if hasRole(tenantId, ['admin', 'doctor']);
      }
      match /patients/{patientId} {
        allow read, write: if inTenant(tenantId);
      }
      match /visits/{visitId} {
        allow read, write: if inTenant(tenantId);
      }
      match /appointments/{apptId} {
        allow read, write: if inTenant(tenantId);
      }
      match /invoices/{invoiceId} {
        allow read, write: if inTenant(tenantId);
      }
      match /pharmacy_stock/{batchId} {
        allow read: if inTenant(tenantId);
        allow write: if hasRole(tenantId, ['admin', 'doctor', 'nurse']);
      }
      match /templates/{templateId} {
        allow read: if inTenant(tenantId);
        allow write: if hasRole(tenantId, ['admin', 'doctor']);
      }
      match /settings/{docId} {
        allow read: if inTenant(tenantId);
        allow write: if hasRole(tenantId, ['admin', 'doctor']);
      }
    }
  }
}
