rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSuperadmin() { return signedIn() && request.auth.token.superadmin == true; }
    function inTenant(tenantId) {
      return signedIn() && (request.auth.token.tenantId == tenantId || isSuperadmin());
    }
    function hasRole(tenantId, roles) {
      return inTenant(tenantId) && request.auth.token.role in roles;
    }

    match /tenants/{tenantId} {
      allow read: if inTenant(tenantId);
      allow write: if isSuperadmin(); // tenants are created by the seed script / admin SDK, or a superadmin via the Superadmin tool

      match /staff/{staffId} {
        allow read: if inTenant(tenantId);
        allow write: if hasRole(tenantId, ['admin', 'doctor']);
      }
      match /patients/{patientId} {
        allow read, write: if inTenant(tenantId);
      }
      match /visits/{visitId} {
        allow read, write: if inTenant(tenantId);
      }
      match /appointments/{apptId} {
        allow read, write: if inTenant(tenantId);
      }
      match /invoices/{invoiceId} {
        allow read, write: if inTenant(tenantId);
      }
      match /pharmacy_stock/{batchId} {
        allow read: if inTenant(tenantId);
        allow write: if hasRole(tenantId, ['admin', 'doctor', 'nurse']) || isSuperadmin();
      }
      match /templates/{templateId} {
        allow read: if inTenant(tenantId);
        allow write: if hasRole(tenantId, ['admin', 'doctor']) || isSuperadmin();
      }
      match /settings/{docId} {
        allow read: if inTenant(tenantId);
        allow write: if hasRole(tenantId, ['admin', 'doctor']) || isSuperadmin();
      }
    }
  }
}
